# Configuración de la API del Contador

# CONTRACT_ID: ID del contrato desplegado en TestNet
# Ejemplo: CDTLBM7PGKSNM7KXXXXXX...XXXXXX
CONTRACT_ID=tu_contract_id_aqui

# Clave pública de la cuenta (source)
PUBLIC_KEY=tu_public_key_aqui

# Red (TestNet o MainNet)
NETWORK=TestNet
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
RPC_URL=https://soroban-testnet.stellar.org

# Puerto del servidor
PORT=3000
