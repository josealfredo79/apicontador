# Configuración de la API del Contador

# CONTRACT_ID: ID del contrato desplegado en TestNet
# Ejemplo: CDTLBM7PGKSNM7KXXXXXX...XXXXXX
CONTRACT_ID=tu_contract_id_aqui

# Claves de la cuenta Stellar (source account)
PUBLIC_KEY=tu_public_key_aqui
SECRET_KEY=tu_secret_key_aqui

# Red (TestNet o MainNet)
NETWORK=TestNet
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
RPC_URL=https://soroban-testnet.stellar.org

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000

# RP_ID para WebAuthn / Passkeys
# - En local: localhost
# - En Railway: tu-app.up.railway.app (sin https://)
RP_ID=localhost
